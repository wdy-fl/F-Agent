# ============================================================
# F-Agent 配置文件示例
# 复制为 workspace/config.yaml 并填入实际的 api_key 即可使用
#   cp config.yaml.example workspace/config.yaml
# ============================================================

# ----------------------------------------------------------
# LLM 模型配置
# ----------------------------------------------------------
llm:
  api_key: "your-api-key-here"           # API 密钥（必填）
  base_url: "https://api.deepseek.com"   # 模型服务地址
  model: "deepseek-v4-pro"               # 模型名称
  context_window: 128000                  # 上下文窗口大小 (tokens)
  max_iterations: 50                      # 单次对话最大 ReAct 迭代次数
  temperature: 0.7                        # 生成温度 (0-1)，越高越随机

# ----------------------------------------------------------
# 工具配置
# ----------------------------------------------------------
tools:
  max_result_size: 50000                  # 工具返回结果最大字节数，超出截断

# ----------------------------------------------------------
# 记忆配置
# ----------------------------------------------------------
memory:
  prefetch_limit: 5                       # 每次对话从数据库预取的相关记忆条数

# ----------------------------------------------------------
# 上下文压缩配置
# ----------------------------------------------------------
compressor:
  threshold: 0.5                          # 压缩触发阈值 (0-1)，Token 使用超过此比例时触发
  min_saving: 0.1                         # 最小压缩收益，低于此比例则跳过压缩
  protected_head: 3                       # 保留最近 N 轮对话不被压缩
  protected_tail_tokens: 20000            # 保留消息尾部 Token 数

# ----------------------------------------------------------
# 路径配置（以下均有默认值，无需修改即可运行）
# ----------------------------------------------------------
# db_path: "workspace/state.db"            # SQLite 数据库路径
# user_profile_path: "workspace/USER.md"   # 用户画像文件路径
# skills_dir: "workspace/skills"           # 技能库目录
# log_dir: "workspace/logs"                # 日志目录